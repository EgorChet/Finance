# Node API
PORT=3000
DATA_DIR=./data
ANALYZER_URL=http://127.0.0.1:8001

# Supabase — required for app data (statements, rules, fixed charges, etc.)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Set STORAGE=local only for offline dev without Supabase (empty defaults)

# Cal card sync (server-side scraper; requires Chromium in API container)
CAL_SYNC_ENABLED=false
# Encrypt persisted Cal browser session at rest (AES-256-GCM). Use a long random string
# or a base64-encoded 32-byte key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CAL_SESSION_ENCRYPTION_KEY=

# Auth
AUTH_PASSWORD=your-shared-password
# Login names (required when auth is enabled) — comma-separated, first user then second
AUTH_LABELS=
# Or set separately:
AUTH_LABEL_EGOR=
AUTH_LABEL_JULIA=
AUTH_SECRET=random-long-string-for-token-signing

# Comma-separated browser origins allowed to call the API (your GitHub Pages URL)
ALLOWED_ORIGINS=https://your-user.github.io

# Vue (build-time)
VITE_API_URL=http://127.0.0.1:3000

# Kaspa portfolio shown in app header (USDT from MEXC KASUSDT ticker)
KAS_BALANCE=347078.071
# KAS_MEXC_SYMBOL=KASUSDT

# FinEx FXCN China ETF — NAV from api.finex-etf.ru (same as finex-etf.ru/calc/nav)
FXCN_LOTS=488

# Gemini — finance chat assistant (server-side only; never expose in Vue)
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash-lite — stable, no thinking overhead)
# GEMINI_MODEL=gemini-2.5-flash-lite
